{
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(assets|public)/(.*)",
            "dest": "/public/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/server.js"
        }
    ]
}